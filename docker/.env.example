# Docker Compose environment file.
# docker-compose.yml reads these for port mapping, secrets, and volume paths.
# Copy to docker/.env and edit as needed.
#
# Agent configuration (LLM endpoints, embeddings, etc.) goes in start.config
# which is mounted into the router container.
#
# Container-internal ports are hardcoded to defaults. Only HOST-SIDE
# ports below can be changed.

# ═══════════════════════════════════════════════════════════════════════
# Secrets (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════

ADMIN_TOKEN=                      # Router admin API token (generate: openssl rand -hex 32)
ADMIN_PASSWORD=                   # Shared web UI admin password for all agents

# ═══════════════════════════════════════════════════════════════════════
# Router configuration
# ═══════════════════════════════════════════════════════════════════════

# EMBEDDED_AGENT_TIMEOUT=720      # ASGI timeout for embedded agent calls (seconds)
# GLOBAL_TIMEOUT_HOURS=1          # Task timeout (hours)
# MAX_DEPTH=10                    # Maximum task nesting depth
# MAX_WIDTH=50                    # Maximum concurrent sub-tasks per parent

# ═══════════════════════════════════════════════════════════════════════
# Coding agent
# ═══════════════════════════════════════════════════════════════════════
#
# The coding agent runs in a separate container. It needs an invitation
# token to register with the router on first boot. After registration,
# credentials are saved in data/credentials.json.
#
# To get a token: use the router admin API or web admin UI after the
# router starts. Then set it here and restart the coding container.

# CODING_INVITATION_TOKEN=        # One-time registration token for coding agent

# ═══════════════════════════════════════════════════════════════════════
# Host-side port mapping
# ═══════════════════════════════════════════════════════════════════════

ROUTER_PORT=8000
WEB_ADMIN_PORT=8080
CHANNEL_PORT=8081
MCP_AGENT_PORT=8082
MCP_SERVER_PORT=8083
MCP_PORT=8084
CRON_PORT=8085
KB_PORT=8086
CODING_PORT=8100
REMINDER_PORT=8101

# ═══════════════════════════════════════════════════════════════════════
# Data persistence
# ═══════════════════════════════════════════════════════════════════════

DATA_ROOT=./data

# ═══════════════════════════════════════════════════════════════════════
# Agent exclusion (router container only)
# ═══════════════════════════════════════════════════════════════════════
# coding_agent runs in its own container — exclude from router's start.sh

EXCLUDE_AGENTS=coding_agent
