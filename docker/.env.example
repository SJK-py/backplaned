# Docker Compose environment file.
# docker-compose.yml reads these for host-side port mapping and volume paths.
# Copy to docker/.env and edit as needed.
#
# Agent configuration (LLM endpoints, embeddings, etc.) goes in start.config
# which is mounted into the router container.
#
# Container-internal ports are hardcoded to defaults (8000, 8080, etc.).
# Only the HOST-SIDE ports below can be changed.

# Secrets (REQUIRED)
ADMIN_TOKEN=                      # Router admin API token (generate: openssl rand -hex 32)
ADMIN_PASSWORD=                   # Shared web UI admin password

# Host-side port mapping (change if you have conflicts)
ROUTER_PORT=8000
WEB_ADMIN_PORT=8080
CHANNEL_PORT=8081
MCP_AGENT_PORT=8082
MCP_SERVER_PORT=8083
MCP_PORT=8084
CRON_PORT=8085
KB_PORT=8086
CODING_PORT=8100
REMINDER_PORT=8101

# Host directory for persistent data volumes
DATA_ROOT=./data
