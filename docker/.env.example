# Docker Compose environment file.
# docker-compose.yml reads these for port mapping and volume paths.
# Copy to docker/.env and edit as needed.
#
# Agent configuration goes in start.config (mounted into the container).

# Router admin token (REQUIRED — generate with: openssl rand -hex 32)
ADMIN_TOKEN=

# Shared admin password for agent web UIs (REQUIRED for web UI access)
ADMIN_PASSWORD=

# Ports
ROUTER_PORT=8000
WEB_ADMIN_PORT=8080
CHANNEL_PORT=8081
MCP_AGENT_PORT=8082
MCP_SERVER_PORT=8083
MCP_PORT=8084
CRON_PORT=8085
KB_PORT=8086
CODING_PORT=8100
REMINDER_PORT=8101

# Host directory for persistent data volumes
DATA_ROOT=./data
