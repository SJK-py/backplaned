# Docker Compose environment file.
# docker-compose.yml reads these for port mapping, secrets, and volume paths.
# Copy to docker/.env and edit as needed.
#
# Agent configuration (LLM endpoints, embeddings, etc.) goes in start.config
# which is mounted into the router container.
#
# Container-internal ports are hardcoded to defaults. Only HOST-SIDE
# ports below can be changed.

# ═══════════════════════════════════════════════════════════════════════
# Secrets (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════

ADMIN_TOKEN=                      # Router admin API token (generate: openssl rand -hex 32)

# ═══════════════════════════════════════════════════════════════════════
# Router configuration
# ═══════════════════════════════════════════════════════════════════════

# EMBEDDED_AGENT_TIMEOUT=720      # ASGI timeout for embedded agent calls (seconds)
# GLOBAL_TIMEOUT_HOURS=1          # Task timeout (hours)
# MAX_DEPTH=10                    # Maximum task nesting depth
# MAX_WIDTH=50                    # Maximum concurrent sub-tasks per parent

# ═══════════════════════════════════════════════════════════════════════
# Coding agent (separate container)
# ═══════════════════════════════════════════════════════════════════════
#
# The coding agent runs in an isolated container. On first boot, register
# it via the web admin UI (Setup tab) or coding agent's own web UI.
# After registration, credentials are saved in data/credentials.json.

CODING_ADMIN_PASSWORD=            # Web UI admin password for coding agent

# ═══════════════════════════════════════════════════════════════════════
# Host-side port mapping
# ═══════════════════════════════════════════════════════════════════════

ROUTER_PORT=8000
WEB_ADMIN_PORT=8080
CHANNEL_PORT=8081
MCP_AGENT_PORT=8082
MCP_SERVER_PORT=8083
MCP_PORT=8084
CRON_PORT=8085
KB_PORT=8086
CODING_PORT=8100
REMINDER_PORT=8101

# ═══════════════════════════════════════════════════════════════════════
# Data persistence
# ═══════════════════════════════════════════════════════════════════════

DATA_ROOT=./data
