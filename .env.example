# DB_PATH defaults to "router.db" (bare metal) if unset.
# In Docker, DB_PATH is set via docker-compose.yml environment to
# persist the database on a mounted volume.  Do NOT uncomment here
# in Docker — it would override the compose-provided value.
# DB_PATH=router.db
PROXYFILE_DIR=proxyfiles
AGENTS_DIR=agents
GLOBAL_TIMEOUT_HOURS=1
EMBEDDED_AGENT_TIMEOUT=720
MAX_DEPTH=10
MAX_WIDTH=50
ADMIN_TOKEN=

# Optional tuning (defaults shown)
# MAX_PAYLOAD_BYTES=1048576
# MAX_FILE_BYTES=52428800
# AGENT_HEALTH_INTERVAL=60
# AGENT_HEALTH_INITIAL_DELAY=30
# AGENT_INFO_REFRESH_CYCLES=10
# TASK_RETENTION_HOURS=72
