{
  "LLM_AGENT_ID": "Agent ID of the LLM inference agent (default: llm_agent)",
  "LLM_MODEL_ID": "Global default model config key for LLM calls (blank = llm_agent default)",
  "USER_MODEL_IDS": "Per-user model override: {\"user_id\": \"model_id\", ...}. Set to 'kagifastgpt' to route a user through Kagi FastGPT instead of the normal agent loop.",
  "SEARCH_PROVIDER": "Web search backend: searxng | brave",
  "SEARXNG_BASE_URL": "Base URL for SearXNG instance (e.g. http://searxng:8080 in Docker, http://localhost:8880 for the default Docker host binding)",
  "BRAVE_API_KEY": "API key for Brave Search (required if provider is brave)",
  "KAGI_TOKEN": "Kagi API token for FastGPT. When set and a user's model_id is 'kagifastgpt', queries go to Kagi FastGPT instead of the LLM agent loop. Falls back to normal loop on failure.",
  "KAGI_FASTGPT_URL": "Kagi FastGPT API endpoint (default: https://kagi.com/api/v0/fastgpt)",
  "SEARCH_MAX_RESULTS": "Default number of search results to return (1-15)",
  "CONTENT_LEN_LIMIT": "Max characters per search result snippet (default: 500, 0 = no limit)",
  "FETCH_MAX_CHARS": "Maximum characters to extract from a fetched webpage",
  "FETCH_TIMEOUT": "Timeout in seconds for a single web fetch",
  "AGENT_TIMEOUT": "Overall timeout in seconds for the full agent loop",
  "MAX_ITERATIONS": "Maximum LLM loop iterations for research (default: 10)",
  "MAX_TOOL_CALLS": "Maximum total tool calls across all iterations (default: 15)",
  "MAX_SEARCHES": "Maximum web searches per request (default: 2)",
  "MAX_FETCHES": "Maximum page fetches per request (default: 3)"
}
