{
  "LLM_AGENT_ID": "Agent ID for LLM calls (default: llm_agent). Routes fact extraction and consolidation through the router",
  "LLM_MODEL_ID": "Global default model ID within llm_agent config. Leave empty for llm_agent default",
  "USER_MODEL_IDS": "Per-user model override: {\"user_id\": \"model_id\", ...}. Takes precedence over LLM_MODEL_ID",
  "EMBED_BASE_URL": "Base URL for OpenAI-compatible embedding endpoint (direct call, not routed through llm_agent)",
  "EMBED_API_KEY": "API key for the embedding provider",
  "EMBED_MODEL": "Embedding model identifier (e.g. Qwen3-Embedding-4B-GGUF)",
  "EMBEDDING_DIMS": "Output dimension of the embedding model (e.g. 768). Required for per-user table creation",
  "DEFAULT_SEARCH_COUNT": "Default number of results returned by memory search"
}
