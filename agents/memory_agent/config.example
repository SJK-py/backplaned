{
  "MEM0_LLM_BASE_URL": "Base URL for OpenAI-compatible LLM endpoint (used for fact extraction and memory consolidation)",
  "MEM0_LLM_API_KEY": "API key for the LLM provider",
  "MEM0_LLM_MODEL": "LLM model identifier for memory operations",
  "MEM0_EMBED_BASE_URL": "Base URL for OpenAI-compatible embedding endpoint",
  "MEM0_EMBED_API_KEY": "API key for the embedding provider",
  "MEM0_EMBED_MODEL": "Embedding model identifier (e.g. Qwen3-Embedding-4B-GGUF)",
  "MEM0_COLLECTION_NAME": "LanceDB table name for storing memories (default: memories)",
  "MEM0_EMBEDDING_DIMS": "Output dimension of the embedding model (e.g. 768). Required for table creation",
  "MEM0_DEFAULT_SEARCH_COUNT": "Default number of results returned by memory search"
}
