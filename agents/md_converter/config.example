{
  "OCR_ENABLED": "Enable OCR plugin for image/scanned PDF extraction (true/false, default false)",
  "OCR_BASE_URL": "Base URL for OpenAI-compatible VLM endpoint used by OCR (e.g. http://localhost:8000/api/v1)",
  "OCR_API_KEY": "API key for the VLM provider",
  "OCR_MODEL": "VLM model identifier for OCR (must support vision/image input)",
  "OCR_PROMPT": "Custom prompt for OCR text extraction (blank = use built-in default)",
  "OCR_NO_PROMPT": "Send only the image with no text prompt (true/false, default false). For dedicated OCR VLMs that expect image-only input",
  "MAX_CONTENT_LENGTH": "Maximum characters to return inline in content (default 30000). Exceeding this returns a file attachment with preview.",
  "PREVIEW_LENGTH": "Characters of preview text when output is returned as file (default 2000)",
  "OUTPUT_DIR": "Directory for output markdown files (default: agent data/output/)"
}
