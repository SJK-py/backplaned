{
  "models": {
    "default": {
      "provider": "LLM provider: openai_compat | openai | anthropic | gemini. 'gemini' uses the native google-genai SDK with full thinking/tool-use support",
      "base_url": "Base URL for OpenAI-compatible endpoint (not used for native openai/anthropic/gemini)",
      "api_key": "API key for the provider",
      "model": "Model identifier (e.g. gpt-4o, claude-sonnet-4-6, gemini-2.5-flash)",
      "max_tokens": "Maximum completion tokens per call (integer)",
      "temperature": "Sampling temperature 0.0-2.0 (float)",
      "timeout": "Timeout in seconds for a single LLM call (integer)",
      "fallback": "Model ID to fall back to on failure (null = fall back to 'default')",
      "available_to_all": "If true, any user can select this model. If false, only users listed in allowed_models may use it (boolean, default: false)",
      "enable_thinking": "Enable thinking/reasoning mode for models that support it (boolean, default: false). Applies to: anthropic (adaptive thinking), gemini (thinkingConfig)",
      "reasoning_effort": "Reasoning effort level: low | medium | high (string). Applies to: openai (o-series), anthropic (output_config.effort), gemini (thinkingBudget/thinkingLevel)",
      "thinking_budget": "Explicit thinking token budget for Gemini 2.5 models (integer, 0-24576). Overrides reasoning_effort mapping. Not needed for Gemini 3.x (use reasoning_effort instead)"
    },
    "fast": "(Example) A second model config for quick/cheap tasks"
  },
  "allowed_models": "Object mapping user_id to comma-separated model IDs the user may access (e.g. {\"alice\": \"default,fast\"})",
  "retry_count": "Number of retries before switching to fallback model (integer)",
  "retry_interval": "Initial delay between retries in seconds (float)",
  "retry_interval_multiplier": "Multiply retry interval by this after each retry (float, e.g. 2.0 for exponential backoff)",
  "total_retry_count": "Maximum total retries across all fallback models (integer)"
}
